# ─────────────────────────────────────────────────────────────────────────────
# Secrets for the runpod-finetune-loop skill.
# Copy to .env (which is gitignored) and fill in. Never commit the real .env.
# In Hermes, put these in ~/.hermes/.env and reference them as ${VAR} in config.yaml.
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED — RunPod API key. Provisions and (importantly) terminates GPU pods.
# Get it: RunPod console -> Settings -> API Keys. Give it read/write.
RUNPOD_API_KEY=

# REQUIRED — Hugging Face token. Must have WRITE scope to push the adapter, and
# read to pull the base model. Also passed into the pod's container env so
# train_lora.py can push_to_hub. Fine-grained token scoped to the target repo is best.
# Get it: huggingface.co/settings/tokens
HF_TOKEN=

# OPTIONAL — GitHub PAT. Only needed if you (a) use the GitHub MCP to log eval
# results, or (b) push commits via token instead of SSH. Fine-grained PAT scoped
# to the chuck26 repo (Contents: read/write, Issues: read/write) is enough.
GITHUB_PERSONAL_ACCESS_TOKEN=

# OPTIONAL — experiment tracking. The training script defaults to report_to="none",
# so leave blank unless you flip on W&B logging.
WANDB_API_KEY=
